// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js Models

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  sentInvites   Invite[]  @relation("UserInvites")

  // Back-relations for data ownership
  ownedCompanies Company[] @relation("CompanyOwner")
  ownedPeople    Person[]  @relation("PersonOwner")
  ownedLeads     Lead[]    @relation("LeadOwner")
  assignedTasks  Task[]    @relation("TaskAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Multi-Tenant Core Models

model Tenant {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  logoUrl      String?
  organization Organization?
  members      Membership[]

  // AI Configuration
  geminiApiKey String?
  aiEnabled    Boolean       @default(true)

  // Tenant Isolated Data
  companies     Company[]
  people        Person[]
  leads         Lead[]
  tasks         Task[]
  emailActivity EmailActivity[]
  invites       Invite[]  @relation("TenantInvites")

  // Billing & Subscriptions
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  planTier               PlanTier  @default(TRIAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlanTier {
  TRIAL
  SOLO
  TEAM
  PRO
  UNLIMITED
}

model Organization {
  id             String  @id @default(cuid())
  tenantId       String  @unique
  name           String
  logoUrl        String?
  billingCountry String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  READ_ONLY
}

model Membership {
  id       String @id @default(cuid())
  userId   String
  tenantId String
  role     Role   @default(MEMBER)

  // Section Access
  canAccessCompanies Boolean @default(true)
  canAccessPeople    Boolean @default(true)
  canAccessLeads     Boolean @default(true)
  canAccessTasks     Boolean @default(true)

  // Visibility Scope: "GLOBAL" or "OWNED"
  visibilityScope String @default("GLOBAL")

  // Operational Rights
  canCreate Boolean @default(true)
  canEdit   Boolean @default(true)
  canDelete Boolean @default(false)
  canExport Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tenantId])
}

model Invite {
  id        String @id @default(cuid())
  email     String
  role      Role   @default(MEMBER)
  
  // Section Access
  canAccessCompanies Boolean @default(true)
  canAccessPeople    Boolean @default(true)
  canAccessLeads     Boolean @default(true)
  canAccessTasks     Boolean @default(true)

  // Visibility Scope: "GLOBAL" or "OWNED"
  visibilityScope String @default("GLOBAL")

  // Operational Rights
  canCreate Boolean @default(true)
  canEdit   Boolean @default(true)
  canDelete Boolean @default(false)
  canExport Boolean @default(false)

  tenantId  String
  inviterId String
  status    String @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  token     String @unique

  tenant  Tenant @relation("TenantInvites", fields: [tenantId], references: [id], onDelete: Cascade)
  inviter       User      @relation("UserInvites", fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, tenantId])
}

// CRM Models

model Company {
  id       String  @id @default(cuid())
  tenantId String
  
  // Basic info (acts as generic display name in lists)
  name     String
  logoUrl  String?

  
  // Entity Classification
  entityType String  @default("COMPANY") // COMPANY or INDIVIDUAL (Persona Física)
  
  // Fiscal Identification (Company)
  legalName  String? // Razón Social
  taxId      String? // CIF / NIF / DNI
  
  // Fiscal Identification (Individual)
  firstName       String?
  lastName        String?
  secondLastName  String?
  
  // Contact Info
  email    String?
  phone    String?
  website  String?

  // Legal Representative (If Company)
  legalRepName     String?
  legalRepLastName String?
  legalRepTaxId    String?
  legalRepEmail    String?
  legalRepPhone    String?
  
  // Fiscal Address
  address         String?
  addressCity     String?
  addressProvince String?
  addressZip      String?
  addressCountry  String? @default("España")
  
  // Operating Address
  useSameAddress    Boolean @default(true)
  opAddress         String?
  opAddressCity     String?
  opAddressProvince String?
  opAddressZip      String?
  opAddressCountry  String?
  
  // Business Information
  companyType    String? // Autónomo, SL, SA, Cooperativa, Otro
  sector         String?
  employeeCount  String?
  revenueRange   String?
  foundationYear Int?
  
  // Bank Details
  iban       String?
  bankOwner  String?
  bankName   String?
  sepaUrl    String?
  
  // Documentation Uploads
  cifUrl        String?
  escriturasUrl String?
  dniUrl        String?
  
  notes    String? @db.Text
  status   String  @default("ACTIVE")
  ownerId  String?

  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner  User?    @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  people Person[]
  leads  Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Person {
  id        String  @id @default(cuid())
  tenantId  String
  companyId String?
  name      String
  lastName  String?
  email     String?
  phone     String?
  jobTitle  String?
  notes     String? @db.Text
  ownerId   String?

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner   User?           @relation("PersonOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  leads   Lead[]
  emails  EmailActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Lead {
  id        String    @id @default(cuid())
  tenantId  String
  companyId String?
  personId  String?
  name      String
  status    String    @default("NEW") // Defines stage: NEW, IN_PROGRESS, WON, LOST
  source    String?
  value     Float?
  notes     String?   @db.Text
  dueDate   DateTime?
  ownerId   String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  person  Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  owner   User?    @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Task {
  id              String    @id @default(cuid())
  tenantId        String
  title           String
  status          String    @default("TODO") // TODO, IN_PROGRESS, COMPLETED
  priority        String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  dueDate         DateTime?
  assigneeId      String?
  relatedEntityId String? // Generic link to Lead/Person/Company if needed
  relatedEntityType String? // "COMPANY", "PERSON", "LEAD"

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignee User?  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model EmailActivity {
  id       String   @id @default(cuid())
  tenantId String
  personId String?
  subject  String
  body     String   @db.Text
  sentAt   DateTime

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  person Person? @relation(fields: [personId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
